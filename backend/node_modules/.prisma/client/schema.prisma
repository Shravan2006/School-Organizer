datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  student
  teacher
  parent
  staff
  admin
}

enum AttendanceStatus {
  present
  absent
  late
  excused
}

enum StaffType {
  librarian
  accountant
  transport_manager
  hostel_warden
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole
  createdAt    DateTime @default(now()) @map("created_at")

  student       Student?
  teacher       Teacher?
  parent        Parent?
  staff         Staff?
  announcements Announcement[]

  @@map("users")
}

model Student {
  id      Int      @id @default(autoincrement())
  userId  Int      @unique @map("user_id")
  classId Int      @map("class_id")
  section String
  rollNo  Int      @map("roll_no")
  dob     DateTime

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  parents     ParentStudent[]
  enrollments Enrollment[]
  attendance  Attendance[]
  submissions Submission[]
  grades      Grade[]
  payments    Payment[]
  bookLoans   BookLoan[]

  @@map("students")
}

model Teacher {
  id               Int    @id @default(autoincrement())
  userId           Int    @unique @map("user_id")
  subjectSpecialty String @map("subject_specialty")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  classes Class[]

  @@map("teachers")
}

model Parent {
  id     Int @id @default(autoincrement())
  userId Int @unique @map("user_id")

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  students ParentStudent[]

  @@map("parents")
}

model ParentStudent {
  parentId  Int @map("parent_id")
  studentId Int @map("student_id")

  parent  Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([parentId, studentId])
  @@map("parent_student")
}

model Staff {
  id        Int       @id @default(autoincrement())
  userId    Int       @unique @map("user_id")
  staffType StaffType @map("staff_type")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("staff")
}

model Class {
  id        Int    @id @default(autoincrement())
  name      String
  section   String
  teacherId Int    @map("teacher_id")

  teacher     Teacher      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  students    Student[]
  enrollments Enrollment[]
  attendance  Attendance[]
  assignments Assignment[]
  exams       Exam[]
  fees        Fee[]

  @@map("classes")
}

model Enrollment {
  studentId    Int      @map("student_id")
  classId      Int      @map("class_id")
  dateEnrolled DateTime @default(now()) @map("date_enrolled")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@id([studentId, classId])
  @@map("enrollments")
}

model Attendance {
  id        Int              @id @default(autoincrement())
  studentId Int              @map("student_id")
  classId   Int              @map("class_id")
  date      DateTime
  status    AttendanceStatus

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@map("attendance")
}

model Assignment {
  id          Int      @id @default(autoincrement())
  classId     Int      @map("class_id")
  title       String
  description String
  dueDate     DateTime @map("due_date")

  class       Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@map("assignments")
}

model Submission {
  id           Int      @id @default(autoincrement())
  assignmentId Int      @map("assignment_id")
  studentId    Int      @map("student_id")
  fileUrl      String   @map("file_url")
  submittedAt  DateTime @default(now()) @map("submitted_at")
  grade        String?

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("submissions")
}

model Exam {
  id      Int      @id @default(autoincrement())
  classId Int      @map("class_id")
  name    String
  date    DateTime

  class  Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  grades Grade[]

  @@map("exams")
}

model Grade {
  id        Int   @id @default(autoincrement())
  examId    Int   @map("exam_id")
  studentId Int   @map("student_id")
  marks     Float
  maxMarks  Float @map("max_marks")

  exam    Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("grades")
}

model Fee {
  id      Int    @id @default(autoincrement())
  classId Int    @map("class_id")
  term    String
  amount  Float

  class    Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@map("fees")
}

model Payment {
  id         Int      @id @default(autoincrement())
  studentId  Int      @map("student_id")
  feeId      Int      @map("fee_id")
  amountPaid Float    @map("amount_paid")
  status     String // e.g. paid, partial, pending
  paidAt     DateTime @default(now()) @map("paid_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  fee     Fee     @relation(fields: [feeId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model LibraryBook {
  id              Int        @id @default(autoincrement())
  title           String
  author          String
  isbn            String     @unique
  copiesAvailable Int        @map("copies_available")
  bookLoans       BookLoan[]

  @@map("library_books")
}

model BookLoan {
  id         Int       @id @default(autoincrement())
  bookId     Int       @map("book_id")
  studentId  Int       @map("student_id")
  issuedAt   DateTime  @default(now()) @map("issued_at")
  dueAt      DateTime  @map("due_at")
  returnedAt DateTime? @map("returned_at")

  book    LibraryBook @relation(fields: [bookId], references: [id], onDelete: Cascade)
  student Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("book_loans")
}

model Announcement {
  id         Int      @id @default(autoincrement())
  postedBy   Int      @map("posted_by")
  roleTarget String   @map("role_target") // can target "all" or specific roles like "student", "teacher"
  title      String
  body       String
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [postedBy], references: [id], onDelete: Cascade)

  @@map("announcements")
}
